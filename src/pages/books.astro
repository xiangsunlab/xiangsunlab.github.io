---
import { getEntry, render } from "astro:content";
import InnerPage from "../components/InnerPage.astro";
import { parseInlineMarkdown } from "../utils/markdown";

const entry = await getEntry("pages", "books");

if (!entry) {
  throw new Error("Missing page content: src/content/pages/books.md");
}

const page = entry.data as Record<string, any>;
const { Content } = await render(entry);
---

<InnerPage
  title={page.title}
  eyebrow={page.eyebrow}
  description={page.description}
  current="books"
  wideHeading
>
  <article class="books-content">
    <Content />
  </article>
</InnerPage>

<style>
  .books-content {
    columns: 2 30rem;
    column-gap: 1.5rem;
  }

  :global(.books-content h2) {
    margin: 0 0 1rem;
    break-after: avoid;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(1.55rem, 2.5vw, 2rem);
    font-weight: 500;
    line-height: 1.15;
  }

  :global(.books-content h2:not(:first-child)) {
    margin-top: 1.5rem;
  }

  :global(.books-content ul) {
    margin: 0 0 1.5rem;
    padding: 1.4rem 1.4rem 1.4rem 2.5rem;
    break-inside: avoid;
    border: 1px solid rgba(76, 46, 91, 0.08);
    border-radius: var(--radius-window);
    background: #f7f3f8;
  }

  :global(.books-content h2:nth-of-type(even) + ul) {
    background: #f1f5f5;
  }

  :global(.books-content li) {
    padding-left: 0.2rem;
    color: var(--color-text);
    font-size: 0.94rem;
    line-height: 1.58;
  }

  :global(.books-content li + li) {
    margin-top: 0.55rem;
  }

  :global(.books-content li ul) {
    margin: 0.65rem 0 0;
    padding: 0 0 0 1.25rem;
    border: 0;
    background: transparent;
  }

  @media (max-width: 42rem) {
    .books-content {
      columns: 1;
    }

    :global(.books-content ul) {
      padding: 1.2rem 1.2rem 1.2rem 2.2rem;
    }
  }
</style>
