---
import InnerPage from "../components/InnerPage.astro";
import { getPageData } from "../data/pages";
import { parseInlineMarkdown } from "../utils/markdown";

const page = await getPageData("photos");
---

<InnerPage title={page.title} eyebrow={page.eyebrow} description={page.description} current="photos">
  {page.photos.length > 0 && (
    <div class="photo-grid">
      {page.photos.map((photo) => (
        <figure>
          <img src={photo.image} alt={photo.alt} loading="lazy" />
          {(photo.title || photo.caption || photo.date) && (
            <figcaption>
              {photo.title && <strong>{photo.title}</strong>}
              {photo.date && <time>{photo.date}</time>}
              {photo.caption && <span set:html={parseInlineMarkdown(photo.caption)}></span>}
            </figcaption>
          )}
        </figure>
      ))}
    </div>
  )}
</InnerPage>

<style>
  .photo-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1rem; }
  figure { margin: 0; overflow: hidden; border: 1px solid var(--color-border); border-radius: var(--radius-window); background: white; }
  img { display: block; width: 100%; height: auto; }
  figcaption { display: grid; grid-template-columns: 1fr auto; gap: 0.25rem 1rem; padding: 1rem; color: var(--color-muted); }
  figcaption strong { color: var(--color-ink); }
  figcaption span { grid-column: 1 / -1; }
  time { font-size: 0.85rem; }
  @media (max-width: 40rem) { .photo-grid { grid-template-columns: 1fr; } }
</style>
