---
import InnerPage from "../components/InnerPage.astro";
import { getPageData } from "../data/pages";
import { parseInlineMarkdown } from "../utils/markdown";

const page = await getPageData("join");
---

<InnerPage title={page.title} eyebrow={page.eyebrow} description={page.description} current="join">
  <section class="welcome" data-reveal>
    <h2 set:html={parseInlineMarkdown(page.welcome)}></h2>
    <ol>
      {page.qualities.map((quality) => <li set:html={parseInlineMarkdown(quality)}></li>)}
    </ol>
  </section>

<div class="opportunity-list">
    {page.opportunities.map((opportunity, index) => {
    
      const isExternal = opportunity.linkUrl && opportunity.linkUrl.startsWith("http");
      
      return (
        <article data-reveal style={`--reveal-delay: ${index * 80}ms`}>
          <h2>{opportunity.title}</h2>
          <p set:html={parseInlineMarkdown(opportunity.description)}></p>
          
          {opportunity.linkUrl && (
            <a 
              href={opportunity.linkUrl} 
              target={isExternal ? "_blank" : undefined} 
              rel={isExternal ? "noreferrer" : undefined}
            >
              {opportunity.linkLabel} <span aria-hidden="true">{isExternal ? "↗" : "→"}</span>
            </a>
          )}
          
          {opportunity.email && (
            <a href={`mailto:${opportunity.email}`}>{opportunity.email} <span aria-hidden="true">→</span></a>
          )}
        </article>
      );
    })}
  </div>

  <aside class="student-highlight" data-reveal>
    <p set:html={parseInlineMarkdown(page.highlightEnglish)}></p>
    <p lang="zh" set:html={parseInlineMarkdown(page.highlightChinese)}></p>
  </aside>
</InnerPage>

<style>
  .welcome {
    padding: clamp(1.5rem, 4vw, 2.5rem);
    border-radius: var(--radius-window);
    background: #f7f3f8;
  }

  .welcome h2,
  article h2 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(1.45rem, 2.4vw, 2rem);
  }

  .welcome ol {
    display: grid;
    gap: 0.65rem;
    margin: 1.25rem 0 0;
    padding-left: 1.4rem;
  }

  .opportunity-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin-top: 1rem;
  }

  article {
    padding: clamp(1.5rem, 3vw, 2rem);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-window);
    background: white;
  }

  article p {
    color: var(--color-muted);
    line-height: 1.65;
  }

  article a {
    color: var(--color-purple);
    font-weight: 800;
  }

  .student-highlight {
    margin-top: 1rem;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    border-left: 0.35rem solid var(--color-purple);
    border-radius: var(--radius-window);
    background: var(--color-purple);
    color: white;
  }

  .student-highlight p {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(1.35rem, 3vw, 2.25rem);
    font-weight: 600;
    line-height: 1.25;
  }

  .student-highlight p + p {
    margin-top: 1rem;
  }

  @media (max-width: 48rem) {
    .opportunity-list {
      grid-template-columns: 1fr;
    }
  }
</style>
