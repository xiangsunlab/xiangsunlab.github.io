---
import InnerPage from "../components/InnerPage.astro";
import NewsList from "../components/NewsList.astro";
import NewsPagination from "../components/NewsPagination.astro";
import { getNewsItems, getNewsPageData, NEWS_PAGE_SIZE } from "../data/news";
import { parseInlineMarkdown } from "../utils/markdown";

const page = await getNewsPageData();
const newsItems = (await getNewsItems()).filter((item) => !item.draft);
const latestNews = newsItems.slice(0, NEWS_PAGE_SIZE);
const totalPages = Math.ceil(newsItems.length / NEWS_PAGE_SIZE);
---

<InnerPage
  title={page.title}
  eyebrow={page.eyebrow}
  description={page.description}
  current="news"
  showDescription={false}
>
  <NewsList items={latestNews} />
  <NewsPagination currentPage={1} totalPages={totalPages} />
</InnerPage>
