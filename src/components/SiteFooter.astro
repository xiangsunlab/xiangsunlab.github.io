---
import { getSiteData } from "../data/pages";
import { parseInlineMarkdown } from "../utils/markdown";

interface Props {
  lang?: "en" | "zh";
}

const { lang = "en" } = Astro.props;
const prefix = lang === "zh" ? "/zh" : "";
const site = await getSiteData();
---

<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-identity">
      <p class="eyebrow">{site.footerEyebrow}</p>
      <h2>{site.footerTitle}</h2>
      <div class="institution-logos" aria-label={site.footerInstitutionsAria}>
        <img
          src={site.footerLogo}
          width="300"
          height="33"
          alt={site.footerLogoAlt}
          loading="lazy"
        />
      </div>
    </div>

    <nav aria-label={site.secondaryNavigationAria}>
      {site.secondaryNavigation.map((link) => (
        <a href={`${prefix}${link.href}`}>{link.label}</a>
      ))}
    </nav>
  </div>
  <div class="footer-bottom">
    <p>{site.copyrightPrefix} 2019 - {new Date().getFullYear()} {site.name}</p>
    <p>{site.footerRight}</p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(76, 46, 91, 0.1);
    background: linear-gradient(180deg, #f7f3f8 0%, #eee7f1 100%);
    color: var(--color-ink);
  }

  .footer-main,
  .footer-bottom {
    width: min(100% - 2rem, 76rem);
    margin: 0 auto;
  }

  .footer-main {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(12rem, 0.5fr);
    gap: 4rem;
    padding: 3.75rem 0 3rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--color-purple);
    font-size: 0.72rem;
    font-weight: 750;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h2 {
    max-width: 32ch;
    margin: 0 0 1.75rem;
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3.5vw, 2.65rem);
    font-weight: 500;
    line-height: 1.12;
  }

  .institution-logos {
    display: flex;
    max-width: 25rem;
    align-items: center;
    gap: 1rem;
    padding: 0.8rem 1rem;
    border: 1px solid rgba(76, 46, 91, 0.1);
    border-radius: var(--radius-window);
    background: white;
    box-shadow: 0 0.35rem 1rem rgba(76, 46, 91, 0.06);
  }

  .institution-logos img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .institution-logos a {
    display: flex;
    min-height: 2.75rem;
    align-items: center;
  }

  nav {
    display: grid;
    align-content: start;
  }

  nav a {
    min-height: 3rem;
    padding: 0.65rem 0;
    border-bottom: 1px solid rgba(76, 46, 91, 0.16);
    color: var(--color-text);
    font-weight: 650;
    text-decoration: none;
    transition: color 180ms ease, padding-left 180ms ease;
  }

  nav a:hover {
    padding-left: 0.25rem;
    color: var(--color-purple);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.35rem 0;
    border-top: 1px solid rgba(76, 46, 91, 0.14);
    color: var(--color-muted);
    font-size: 0.78rem;
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (max-width: 44rem) {
    .footer-main {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .footer-bottom {
      display: grid;
    }
  }
</style>
