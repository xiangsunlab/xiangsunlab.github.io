---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "./SiteHeader.astro";
import SiteFooter from "./SiteFooter.astro";
import { getSiteData } from "../data/pages";
import { parseInlineMarkdown } from "../utils/markdown";

interface Props {
  title: string;
  eyebrow: string;
  description: string;
  current: string;
  lang?: "en" | "zh";
  showDescription?: boolean;
  wideHeading?: boolean;
}

const {
  title,
  eyebrow,
  description,
  current,
  lang = "en",
  showDescription = true,
  wideHeading = false,
} = Astro.props;
const site = await getSiteData();
---

<BaseLayout title={`${title} | ${site.name}`} description={description} lang={lang}>
  <SiteHeader lang={lang} current={current} />
  <main id="main-content" class="inner-page">
    <div class:list={["inner-heading", { "inner-heading--wide": wideHeading }]} data-reveal>
      <p>{eyebrow}</p>
      <h1>{title}</h1>
      {showDescription && <div class="intro">{description}</div>}
    </div>
    <div class:list={["content-slot", { "content-slot--compact": !showDescription }]}>
      <slot />
    </div>
  </main>
  <SiteFooter lang={lang} />
</BaseLayout>

<style>
  .inner-page {
    width: min(100% - 2rem, 76rem);
    min-height: 62vh;
    margin: 0 auto;
    padding: clamp(1.2rem, 2.7vw, 2.4rem) 0 clamp(4rem, 9vw, 8rem);
  }

  .inner-heading {
    max-width: none;
  }

  .inner-heading--wide {
    max-width: none;
  }

  .inner-heading > p {
    margin: 0 0 1rem;
    color: var(--color-purple);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  h1 {
    margin: 0;
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 6.8rem);
    font-weight: 500;
    letter-spacing: -0.045em;
    line-height: 0.95;
  }

  .intro {
    max-width: none;
    margin-top: 2rem;
    color: var(--color-muted);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
  }

  .content-slot {
    margin-top: 2rem;
  }

  .content-slot--compact {
    margin-top: 2rem;
  }
</style>
